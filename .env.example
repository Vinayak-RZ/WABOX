# WABOX local development — copy to `.env` and adjust paths.
# `.env` is gitignored; this file is the committed template.

# --- Sandbox policy ---
# PATH mirror: minimal (fast DACL) | full (all PATH dirs) | none (workspace only)
WABOX_MIRROR_ENV=minimal

# Project root for agent read/write (use forward slashes on Windows)
WABOX_WORKSPACE_PATH=C:/path/to/your/project

# Per-exec timeout in ms (first MXC spawn on appcontainer-dacl can be slow)
WABOX_EXEC_TIMEOUT_MS=300000

# Session JSON logs directory (relative to cwd or absolute)
WABOX_LOG_DIR=.wabox/sessions

# --- Debugging ---
# off | info (1) | verbose | trace — exec/policy logs; trace streams live stdout/stderr
WABOX_DEBUG=1

# 1 = JSON lines to stderr (with WABOX_DEBUG enabled)
# WABOX_DEBUG_JSON=1

# diagnose writes .wabox/diagnostics/latest.json (set 0 to skip)
# WABOX_DIAGNOSE_JSON=1

# --- Benchmark (npm run benchmark) ---
WABOX_DOCKER_IMAGE=node:22-alpine
WABOX_BENCHMARK_ITERATIONS=3

# If Node/npm live on a drive root (e.g. D:\node.exe), move them into a subfolder:
#   mkdir D:\nodejs
#   move D:\node.exe D:\nodejs\
#   move D:\npm* D:\nodejs\
# Then set:
# WABOX_TOOLS_DIR=D:/nodejs
# WABOX_INTEGRATION=1
