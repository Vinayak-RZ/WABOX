{
  "name": "wabox",
  "version": "0.1.0",
  "description": "Windows-native agent sandbox wrapper around @microsoft/mxc-sdk",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "cross-env WABOX_INTEGRATION=1 vitest run tests/integration",
    "spike": "tsx scripts/mxc-spike.ts",
    "example": "tsx examples/minimal-agent.ts",
    "benchmark": "tsx scripts/benchmark-wabox-vs-docker.ts",
    "diagnose": "tsx scripts/diagnose-mxc.ts",
    "warmup": "tsx scripts/warmup-mxc.ts",
    "probe:node": "tsx scripts/probe-node-sandbox.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@microsoft/mxc-sdk": "0.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
